NODE_ENV=development

# HTTP server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Hardhat / Ethereum RPC
CHAIN_RPC_URL=http://127.0.0.1:8545

# Deployed EvidenceRegistry contract address (filled after hardhat deploy)
CONTRACT_ADDRESS=0xYourDeployedContractAddressHere

# JWT authentication (MVP: symmetric HS256)
JWT_SECRET=change-me-in-production
JWT_ISSUER=chainguard.local
JWT_AUDIENCE=chainguard.officers
JWT_REQUIRED_ROLE=first_responder

# SQLite database file
SQLITE_PATH=./backend/data/chainguard.db

# Rate limits (per minute)
RL_SUBMIT_PER_MIN=30
RL_UPLOAD_PER_MIN=10
RL_VERIFY_PER_MIN=60
RL_LIST_PER_MIN=120

