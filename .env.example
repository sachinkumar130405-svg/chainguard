# ──── PRODUCTION / DEPLOYMENT ENVIRONMENT ────
# Documented in docs/DEPLOYMENT.md

NODE_ENV=production

# URLs & CORS
PORT=3001
FRONTEND_URL=https://chainguard.vercel.app
CORS_ORIGIN=https://chainguard.vercel.app

# Blockchain (Sepolia Testnet)
# Replace with your provider URL (Alchemy/Infura)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
CHAIN_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Deployer / Officer Wallet
PRIVATE_KEY=your_private_key_here

# Deployed EvidenceRegistry contract address
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Authentication (JWT)
JWT_SECRET=your_jwt_secret_here
JWT_ISSUER=chainguard.local
JWT_AUDIENCE=chainguard.officers
JWT_REQUIRED_ROLE=first_responder

# Feature Toggles
MOCK_BLOCKCHAIN=0
USE_MOCK_STORAGE=0
USE_MOCK_AUTH=false

# Storage (Pinata IPFS)
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here

# SQLite Database
SQLITE_PATH=./backend/data/chainguard.db

# Rate Limits (Per Minute)
RL_SUBMIT_PER_MIN=30
RL_UPLOAD_PER_MIN=10
RL_VERIFY_PER_MIN=60
RL_LIST_PER_MIN=120

