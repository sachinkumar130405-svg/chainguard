# ──── ChainGuard Backend ────
PORT=3000
NODE_ENV=production

# Blockchain (Sepolia or Local)
# RPC_URL is the standard for Sepolia providers (Alchemy/Infura)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
CHAIN_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Deployed EvidenceRegistry contract address
CONTRACT_ADDRESS=0x...

# JWT Authentication
JWT_SECRET=your_secret_here
JWT_ISSUER=chainguard.local
JWT_AUDIENCE=chainguard.officers
JWT_REQUIRED_ROLE=first_responder

# SQLite Database
SQLITE_PATH=./backend/data/chainguard.db

# CORS
CORS_ORIGIN=https://chainguard.vercel.app

# Storage
# Set USE_MOCK_STORAGE=0 to enable real IPFS pinning via Pinata
USE_MOCK_STORAGE=1
PINATA_API_KEY=your_key
PINATA_SECRET_KEY=your_secret

# Rate Limits
RL_SUBMIT_PER_MIN=30
RL_UPLOAD_PER_MIN=10
RL_VERIFY_PER_MIN=60
RL_LIST_PER_MIN=120
