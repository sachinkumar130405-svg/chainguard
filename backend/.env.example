# ──── ChainGuard Backend ────

PORT=3001
NODE_ENV=development

# Blockchain (Hardhat local node)
BLOCKCHAIN_URL=http://127.0.0.1:8545

# JWT Authentication
JWT_SECRET=chainguard-dev-secret-change-in-production
JWT_EXPIRES_IN=24h

# SQLite Database
DB_PATH=./data/chainguard.db

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# IPFS Storage (Pinata)
# Set USE_MOCK_STORAGE to 0 to enable real IPFS pinning via Pinata
USE_MOCK_STORAGE=1
PINATA_JWT=your_pinata_jwt_here
