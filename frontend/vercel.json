{
    "cleanUrls": true,
    "trailingSlash": false,
    "build": {
        "env": {
            "VITE_API_URL": "@vite_api_url",
            "VITE_CONTRACT_ADDRESS": "@vite_contract_address"
        }
    },
    "rewrites": [
        {
            "source": "/capture/(.*)",
            "destination": "/capture/index.html"
        },
        {
            "source": "/capture",
            "destination": "/capture/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}