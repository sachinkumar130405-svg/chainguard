{
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
        {
            "source": "/capture/(.*)",
            "destination": "/capture/index.html"
        },
        {
            "source": "/capture",
            "destination": "/capture/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}